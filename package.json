{
  "name": "@takk/noeticos",
  "version": "1.0.0",
  "description": "NoeticOS: the JIT compiler for agents. Zero-runtime-dependency adaptive runtime tuning for production agents: classifies every task into 10 task kinds plus an unknown fallback, learns the optimal model, temperature, top-p, max turns, retry budget, and context share per (agent, task class) pair with confidence-bound bandits, applies changes only through deterministic canary rollouts with statistically gated promotion and automatic rollback (exploration never touches baseline traffic), and records every decision with numeric evidence in an append-only audit log. OpenTelemetry GenAI spans as input, packaged Vercel AI SDK middleware (generateText and streamText), a local HTTP bridge for non-Node runtimes, bridges for @takk/keymesh, @takk/modelchain, and @takk/behavioralai. Works in Node, Edge runtimes (Cloudflare Workers, Vercel Edge, Deno, Bun) and the browser.",
  "keywords": [
    "adaptive-runtime",
    "auto-tuning",
    "parameter-tuning",
    "multi-armed-bandit",
    "contextual-bandit",
    "online-learning",
    "runtime-intelligence",
    "ai-agents",
    "llm",
    "agent-optimization",
    "cost-optimization",
    "canary",
    "safe-rollout",
    "task-classification",
    "decision-audit",
    "vercel-ai-sdk",
    "opentelemetry",
    "otel",
    "gen-ai",
    "hermes-agent",
    "mcp",
    "edge",
    "cloudflare-workers",
    "typescript"
  ],
  "homepage": "https://github.com/davccavalcante/noeticos",
  "bugs": {
    "url": "https://github.com/davccavalcante/noeticos/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davccavalcante/noeticos.git"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "David C Cavalcante",
    "email": "davcavalcante@proton.me",
    "url": "https://takk.ag"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./otel": {
      "import": {
        "types": "./dist/otel/index.d.ts",
        "default": "./dist/otel/index.js"
      },
      "require": {
        "types": "./dist/otel/index.d.cts",
        "default": "./dist/otel/index.cjs"
      }
    },
    "./vercel": {
      "import": {
        "types": "./dist/vercel/index.d.ts",
        "default": "./dist/vercel/index.js"
      },
      "require": {
        "types": "./dist/vercel/index.d.cts",
        "default": "./dist/vercel/index.cjs"
      }
    },
    "./integrations": {
      "import": {
        "types": "./dist/integrations/index.d.ts",
        "default": "./dist/integrations/index.js"
      },
      "require": {
        "types": "./dist/integrations/index.d.cts",
        "default": "./dist/integrations/index.cjs"
      }
    },
    "./web": {
      "import": {
        "types": "./dist/web/index.d.ts",
        "browser": "./dist/web/index.js",
        "default": "./dist/web/index.js"
      },
      "require": {
        "types": "./dist/web/index.d.cts",
        "default": "./dist/web/index.cjs"
      }
    },
    "./edge": {
      "import": {
        "types": "./dist/edge/index.d.ts",
        "worker": "./dist/edge/index.js",
        "default": "./dist/edge/index.js"
      },
      "require": {
        "types": "./dist/edge/index.d.cts",
        "default": "./dist/edge/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "noeticos": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage .tsbuildinfo",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "publint": "publint",
    "attw": "attw --pack --ignore-rules=no-resolution",
    "size": "size-limit",
    "prepack": "pnpm run build",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run smoke:dist && pnpm run publint",
    "smoke:dist": "node scripts/smoke-dist.mjs"
  },
  "peerDependencies": {
    "@takk/behavioralai": ">=1.0.0",
    "@takk/keymesh": ">=1.0.0",
    "@takk/modelchain": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@takk/behavioralai": {
      "optional": true
    },
    "@takk/keymesh": {
      "optional": true
    },
    "@takk/modelchain": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.34.1",
  "sideEffects": false,
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@biomejs/biome": "^2.5.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@takk/behavioralai": "^1.0.0",
    "@takk/keymesh": "^1.0.0",
    "@takk/modelchain": "^1.0.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "publint": "^0.3.21",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
